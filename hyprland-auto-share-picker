# https://wiki.hypr.land/Hypr-Ecosystem/xdg-desktop-portal-hyprland/#configuration

screencopy {
  custom_picker_binary = hyprland-auto-share-picker
  allow_token_by_default = true
  max_fps = 0 # (No limit)
}
EOF
}

xdph_config_recommended() {
  cat <<'EOF'
# https://wiki.hypr.land/Hypr-Ecosystem/xdg-desktop-portal-hyprland/#configuration

screencopy {
  custom_picker_binary = hyprland-auto-share-picker
  allow_token_by_default = true
}
EOF
}

xdph_config_minimal() {
  cat <<'EOF'
# https://wiki.hypr.land/Hypr-Ecosystem/xdg-desktop-portal-hyprland/#configuration

screencopy {
  custom_picker_binary = hyprland-auto-share-picker
}
EOF
}

xdph_apply_config() {
  local config_identifier="$1" # Index or Name of the config
  if [ "$#" -eq 0 ]; then
    msg "not enough arguments supplied" "error"
    echo "$MSG_ERR"
  fi

  case ${config_identifier,,} in
  0 | skip)
    echo "$MSG_OK"
    ;;
  1 | minimal)
    write_file "$HYPRLAND_XDPH_CONFIG_FILE" "$(xdph_config_minimal)"
    ;;
  2 | recommended)
    write_file "$HYPRLAND_XDPH_CONFIG_FILE" "$(xdph_config_recommended)"
    ;;
  3 | extended)
    write_file "$HYPRLAND_XDPH_CONFIG_FILE" "$(xdph_config_extended)"
    ;;
  *)
    msg "unknown config name" "error"
    echo "$MSG_ERR"
    ;;
  esac
}

xdph_print_config_helper() {
  local config_index="$1"   # Integer
  local config_name="$2"    # String
  local config_content="$3" # String (Multi-Line)

  local desired_length="90"

  if ! [ "$#" -eq 3 ]; then
    msg "not enough arguments supplied" "error"
    echo "$MSG_ERR"
    return 1
  fi

  echo -e ""
  echo -e "$(pad_right "${BLUE}${ST}          ${R}${B}${CYAN} ($config_index) \"$config_name\" Config ${BLUE}${ST}" "$desired_length" " ")${R}"
  echo -e "$config_content"
  echo -e "$(pad_right "${BLUE}${ST}${B}" "$desired_length" " ")${R}"
  echo -e ""
}

xdph_print_configs() {
  xdph_print_config_helper "1" "MINIMAL" "$(xdph_config_minimal)"
  xdph_print_config_helper "2" "RECOMMENDED" "$(xdph_config_recommended)"
  xdph_print_config_helper "3" "EXTENDED" "$(xdph_config_extended)"
}

xdph_config_helper() {
  local selected_config=""
  local selected_config_name=""
  local error_message=""

  while [[ "$selected_config" == "" ]]; do
    clear
    xdph_print_configs

    echo ""
    echo "$error_message"
    error_message=""
    echo ""

    local temp_selected_config=$(read_string "Which config do you want to install? (Numbers and strings possible)" "RECOMMENDED")

    case ${temp_selected_config,,} in
    1 | minimal)
      selected_config="1"
      selected_config_name="Minimal"
      break
      ;;
    2 | recommended)
      selected_config="2"
      selected_config_name="Recommended"
      break
      ;;
    3 | extended)
      selected_config="3"
      selected_config_name="Extended"
      break
      ;;
    *)
      error_message="[ERROR] Invalid selection. Use numbers or the name of the config (Example: \"2\" or \"RECOMMENDED\")"
      ;;
    esac
  done

  xdph_apply_config $selected_config

  sleep 2.0

  clear
  local xdph_restart_now=$(read_yes_no "Do you want to restart XDPH now? (You can alternatively restart your system)" "y")
  if [[ "$xdph_restart_now" == "y" ]]; then
    xdph_restart
    echo "Done"
  else
    echo "Skipping.."
  fi
}

setup() {
  # Setup function for creating the config folder and files.
  local force="$1" # If equals "force", replaces configs with defaults.
  msg "setup( \"$force\" )" "debug"

  # Check if the main config folder doesnt exist or --setup is passed.
  if ! [ -d "$AUTO_SHARE_PICKER_FOLDER" ] || [[ "$force" == "force" ]]; then
    # Create main folder
    mkdir -p "$AUTO_SHARE_PICKER_FOLDER"

    # Create empty SELECTION-TEMP file
    clear_temp_selection

    # Create empty SELECTION-DEFAULT file
    clear_default_selection

    # Create MANUAL-PICKER default file.
    set_manual_picker "hyprland-share-picker"
  fi
}

quick_install() {
  local dest="/usr/bin/hyprland-auto-share-picker"

  if [[ -f "$dest" ]]; then
    local force_answer=$(read_yes_no "Already installed. Overwrite?", "n")
    [[ "$force_answer" == "n" ]] && return 1
  fi

  sudo cp "$SCRIPT_PATH" "$dest"
  sudo chmod +x "$dest"
  msg "Installed to $dest" "ok"
  echo "$MSG_OK"
}

run_wizard() {
  clear
  local install=$(read_yes_no "Do you want to install the script to \"/usr/bin/hyprland-auto-share-picker\"? (requires sudo)" "y")
  if [[ "$install" == "y" ]]; then
    echo "Installing.."
    quick_install
    echo "Done"
  else
    echo "Skipping installation.."
  fi
  sleep 2.0

  clear
  xdph_print_configs
  echo ""
  echo ""
  echo ""
  local xdph_apply=$(read_yes_no "Do you want to apply one of the configs above? (Has to be done manually otherwise) " "y")
  if [[ "$xdph_apply" == "y" ]]; then
    xdph_config_helper
  else
    echo "Skipping .."
  fi
  sleep 2.0

  local picker_worked=""
  while true; do
    clear
    local picker_selected=$(read_string "Which Manual Picker do you prefer to use?" "hyprland-share-picker")
    echo "Testing Picker.."
    sleep 1.0
    local picker_test_ouput="$("$picker_selected")"
    echo "SELECTION-STRING: $picker_test_ouput"
    echo ""

    if [[ "$picker_test_ouput" == "[SELECTION]"* ]]; then
      echo "The picker returned a valid SELECTION-STRING. Setting as default Picker.."
      set_manual_picker "$picker_selected"
      picker_worked="true"
      sleep 3.0 # Give the user some more time to read.
      break
    else
      echo "The selected Picker didn't return a valid SELECTION-STRING"
      local picker_try_again=$(read_yes_no "Do you want to try again?" "y")
      if [[ "$picker_try_again" == "n" ]]; then
        local picker_force_set=$(read_yes_no "Do you still want to set \"$picker_selected\" as your default picker?" "n")
        if [[ "$picker_force_set" == "y" ]]; then
          set_manual_picker "$select_picker"
        else
          echo "Skipping.."
        fi
        break
      fi
    fi
  done

  if [[ "$picker_worked" == "true" ]]; then
    clear
    sleep 2.0

    local default_pick_now=$(read_yes_no "Do you want to set a default SELECTION-STRING using your picker right now?" "y")
    if [[ "$default_pick_now" == "y" ]]; then
      set_default_selection "$(picker)"
    else
      echo "Skipping.."
    fi
  fi
  sleep 2.0

  clear
  echo "Wizard finished!"
  read -p "Press Enter to continue..."
  exit 0
}

