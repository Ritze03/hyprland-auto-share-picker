  xdph_config_helper
  exit 0
  ;;
--xdph-print-configs)
  xdph_print_configs
  exit 0
  ;;
--xdph-apply-config)
  xdph_apply_config "$2"
  exit 0
  ;;
--xdph-restart)
  xdph_restart
  exit 0
  ;;
* | --allow-token)
  # Do nothing and let "$@" handle it.
  ;;
esac

# Parse SELECTION-STRING
selection_string_parsed_temp=$(replace_variables "$1")
if [[ "$1" == "[SELECTION]"* ]] || [[ "$selection_string_parsed_temp" == "[SELECTION]"* ]]; then
  set_temp_selection "$1"
  exit 0
fi

# Temp File
if [[ "$(get_temp_selection)" != "" ]]; then
  echo "$(replace_variables $(pop_temp_selection))"
  exit 0
fi

# Default File
if [[ "$(get_default_selection)" != "" ]]; then
  echo "$(replace_variables $(get_default_selection))"
  exit 0
fi

picker "$@"

exit 0
