#!/bin/bash

# hyprland-auto-share-picker's main directory
AUTO_SHARE_PICKER_FOLDER="$HOME/.config/hyprland-auto-share-picker/"

# If this file exists, it's value will always be used!
AUTO_SHARE_PICKER_DEFAULT_FILE_NAME="SELECTION-DEFAULT"

# If this file exists, it's value will be used once. (one-time selection). The file is deleted afterwards.
AUTO_SHARE_PICKER_TEMP_FILE_NAME="SELECTION-TEMP"
AUTO_SHARE_MANUAL_PICKER_FILE_NAME="MANUAL-PICKER"

# Hyprland XDPH file
HYPRLAND_XDPH_CONFIG_FILE="$HOME/.config/hypr/xdph.conf"

# Generate full paths.
AUTO_SHARE_PICKER_DEFAULT_FILE="$AUTO_SHARE_PICKER_FOLDER$AUTO_SHARE_PICKER_DEFAULT_FILE_NAME"
AUTO_SHARE_PICKER_TEMP_FILE="$AUTO_SHARE_PICKER_FOLDER$AUTO_SHARE_PICKER_TEMP_FILE_NAME"
AUTO_SHARE_MANUAL_PICKER_FILE="$AUTO_SHARE_PICKER_FOLDER$AUTO_SHARE_MANUAL_PICKER_FILE_NAME"

# Script Path
SCRIPT_PATH="${BASH_SOURCE[0]}"

# Version
VERSION="BETA-0.1"

# Styles and Colors
B=$'\033[1m'  # Bold
UL=$'\033[4m' # Underline
ST=$'\033[9m' # Strikethrough
R=$'\033[0m'  # Reset all

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'

# Messages
MSG_OK="ok"
MSG_ERR="err"

# Helper function
strip_ansi() {
  local text="$1"

  printf '%s' "$text" | sed -E 's/\\033/\x1b/g' | sed -E 's/\x1b\[[0-9;]*[a-zA-Z]//g'
}

visible_length() {
  local text="$1" # String: Text

  local plain_text=$(strip_ansi "$text")
  local visible_length=${#plain_text}

  echo "$visible_length"
}

pad_right() {
  local text="$1"              # String: Input Text
  local desired_length="$2"    # Integer: Desired Text length
  local filler_char="${3:0:1}" # String: Only takes the first char as the filler character

  local current_length=$(visible_length "$text")

  if ((current_length >= desired_length)); then
    echo "$text"
    return 0
  fi

  local result="$text"
  local padding_length=$(($desired_length - $current_length))

  for ((i = 0; i < padding_length; i++)); do
    result="$result$filler_char"
  done

  echo "$result"
  return 0
}

msg() {
  if [ "${HASP_LOG}" != "1" ]; then
    return 0
  fi

  local message="$1" # message content
  local type="$2"    # message type log/ok/info/warn/error/debug (Default: log)

  if [ $# -eq 0 ]; then
    >&2 echo ""
    return 0
  elif [ $# -eq 1 ]; then
    type="log"
  fi

  local prefix=""
  case ${type,,} in
  ok)
    prefix="${R}${B}${BLUE}[ OK ]${R} "
    ;;
  info)
    prefix="${R}${B}${BLUE}[INFO]${R} "
    ;;
  warn)
    prefix="${R}${B}${YELLOW}[WARN]${R} "
    ;;
  error)
    prefix="${R}${UL}${B}${RED}[ERROR]${R} "
    ;;
  debug)
    prefix="${R}${CYAN}[DEBUG]${R} "
    ;;
  log) ;&
  *)
    prefix="${R}[LOG]${R} "
    ;;
  esac

  >&2 echo -e "$prefix""$message"

  return 0
}

# Returns "y" or "n"
read_yes_no() {
  local prompt="$1"      # String: Prompt Text
  local default="${2,,}" # String: y/yes / n/no / none(default)

  local answer=""
  local default_text=""

  if [ "$#" -eq 0 ]; then
    msg "Not enough arguments supplied!" "error"
    echo "$MSG_ERR"
    return 1
  elif [ "$#" -eq 1 ]; then
    default="none"
  fi

  case "$default" in
  y | yes)
    default_text="[Y/n]"
    default="y"
    ;;
  n | no)
    default_text="[y/N]"
    default="n"
    ;;
  none) ;&
  *)
    default_text="[y/n]"
    default="none"
    ;;
  esac

  while [ "$answer" == "" ]; do
    local temp_answer=""
    read -p "$prompt $default_text: " temp_answer

    case "$temp_answer" in
    y | yes)
      answer="y"
      ;;
    n | no)
      answer="n"
      ;;
    "")
      if ! [[ "$default" == "none" ]]; then
        answer="$default"
      else
        msg "invalid response, try again" "error"
        >&2 echo "invalid response, try again"
      fi
      ;;
    *)
      msg "invalid response, try again" "error"
      >&2 echo "invalid response, try again"
      ;;
    esac
  done

  echo $answer

  return 0
}

read_string() {
  local prompt="$1"  # String: Prompt Text
  local default="$2" # String: Default Text

  local answer=""

  if [ "$#" -eq 0 ]; then
    msg "Not enough arguments supplied!" "error"
    echo "$MSG_ERR"
    return 1
  fi

  read -p "$prompt [$default]: " answer

  if [[ "$answer" == "" ]]; then
    answer="$default"
  fi

  echo "$answer"
  return 0
}

read_file() {
  local file="$1" # path_to_file
  msg "read_file( \"$file\" )" "debug"
  if [ "$#" -eq 1 ] && [ -f "$file" ]; then
    cat "$file"
  fi
}

write_file() {
  local file="$1"    # path_to_file
  local content="$2" # new content
  msg "write_file( \"$file\", \"$content\" )" "debug"

  if [ "$#" -eq 2 ]; then
    # Create file, if doesnt exist.
    if ! [ -f "$file" ]; then
      touch "$file"
    fi
    echo "$content" >"$file"
    echo "$MSG_OK"
    return 0
  else
    msg "Not enough arguments supplied!" "error"
    echo "$MSG_ERR"
    return 1
  fi
}

# Getter/Setter
get_temp_selection() {
  read_file "$AUTO_SHARE_PICKER_TEMP_FILE"
}

set_temp_selection() {
  write_file "$AUTO_SHARE_PICKER_TEMP_FILE" "$1"
}

clear_temp_selection() {
  set_temp_selection ""
}

pop_temp_selection() {
  get_temp_selection
  clear_temp_selection >/dev/null
}

get_default_selection() {
  read_file "$AUTO_SHARE_PICKER_DEFAULT_FILE"
}

set_default_selection() {
  write_file "$AUTO_SHARE_PICKER_DEFAULT_FILE" "$1"
}

clear_default_selection() {
  set_default_selection ""
}

get_manual_picker() {
  read_file "$AUTO_SHARE_MANUAL_PICKER_FILE"
}

set_manual_picker() {
  write_file "$AUTO_SHARE_MANUAL_PICKER_FILE" "$1"
}

get_active_monitor() {
  echo "$(hyprctl activeworkspace -j | jq -r '.monitor')"
}

get_active_monitor_selection() {
  echo "[SELECTION]/screen:$(get_active_monitor)"
}

get_active_monitor_selection_token() {
  echo "[SELECTION]r/screen:$(get_active_monitor)"
}

get_active_window() {
  echo "$(hyprctl activewindow -j | jq -r '.address')"
}

replace_variables() {
  local selection_string="$1" # String: Original Selection String
  selection_string="${selection_string//"%AM%"/"$(get_active_monitor)"}"
  selection_string="${selection_string//"%ACTIVE-MONITOR%"/"$(get_active_monitor)"}"
  selection_string="${selection_string//"%AMS%"/"$(get_active_monitor_selection)"}"
  selection_string="${selection_string//"%ACTIVE-MONITOR-SELECTION%"/"$(get_active_monitor_selection)"}"
  selection_string="${selection_string//"%AMST%"/"$(get_active_monitor_selection_token)"}"
  selection_string="${selection_string//"%ACTIVE-MONITOR-SELECTION-TOKEN%"/"$(get_active_monitor_selection_token)"}"
  echo "$selection_string"
}

# Core Functions
picker() {
  $(get_manual_picker) "$@"
  return 0
}

xdph_restart() {
  sleep 1
  killall -e xdg-desktop-portal-hyprland
  killall xdg-desktop-portal
  nohup /usr/lib/xdg-desktop-portal-hyprland >/dev/null 2>&1 &
  sleep 2
  nohup /usr/lib/xdg-desktop-portal >/dev/null 2>&1 &
}

xdph_config_extended() {
